.queue-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-icon {
  margin-bottom: 60rpx;
}

.icon-loading {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  animation: spin 1s linear infinite;
}

.icon-success {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #4cd964;
  position: relative;
}

.icon-success::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
  color: #fff;
}

.icon-failed {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ff3b30;
  position: relative;
}

.icon-failed::after {
  content: '✕';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
  color: #fff;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.status-message {
  font-size: 36rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
  margin-bottom: 60rpx;
}

.progress-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

.poll-info {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.poll-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.poll-count {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.tips {
  margin-bottom: 80rpx;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}

.cancel-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.cancel-btn:active {
  background: rgba(255, 255, 255, 0.3);
}