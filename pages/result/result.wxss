.page {
  min-height: 100vh;
  background: #0f0f23;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
}

/* Perfect Achievement Badge */
.perfect-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  animation: badgePop 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes badgePop {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.badge-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
  animation: badgeShine 2s ease-in-out infinite;
}

@keyframes badgeShine {
  0%, 100% {
    transform: rotate(-5deg) scale(1);
    filter: drop-shadow(0 0 10rpx rgba(255, 215, 0, 0.5));
  }
  50% {
    transform: rotate(5deg) scale(1.1);
    filter: drop-shadow(0 0 20rpx rgba(255, 215, 0, 0.8));
  }
}

.badge-text {
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.badge-desc {
  font-size: 28rpx;
  color: #00D9A5;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.label {
  font-size: 32rpx;
  color: #888;
}

/* Score Ring */
.score-ring-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.score-ring-container.perfect-ring .ring-outer {
  animation: ringPulse 1.5s ease-in-out infinite;
  box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.3);
}

@keyframes ringPulse {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
  }
  50% {
    box-shadow: 0 0 50rpx rgba(255, 215, 0, 0.6);
  }
}

.score-ring {
  width: 240rpx;
  height: 240rpx;
  position: relative;
}

.ring-outer {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-inner {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #0f0f23;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #00D9A5;
}

.score-total {
  font-size: 32rpx;
  color: #666;
}

.accuracy-text {
  font-size: 28rpx;
  color: #888;
  margin-top: 20rpx;
}

/* Action Card */
.action-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx;
  background: linear-gradient(135deg, #1a3a2e 0%, #1a2a3e 100%);
  border-radius: 24rpx;
  margin-bottom: 50rpx;
  border: 2rpx solid #00D9A5;
}

.action-card.retest-card {
  background: linear-gradient(135deg, #1a2a3e 0%, #2a1a3e 100%);
  border: 2rpx solid #8B5CF6;
}

.action-icon {
  font-size: 48rpx;
}

.action-content {
  flex: 1;
}

.action-label {
  display: block;
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
}

/* Buttons */
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.btn-row .btn-primary,
.btn-row .btn-secondary {
  flex: 1;
  margin: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #00D9A5 0%, #00B894 100%);
  color: #0f0f23;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #1a1a35;
  color: #888;
  font-size: 30rpx;
  border-radius: 50rpx;
  padding: 24rpx;
  border: 2rpx solid #333;
}

.btn-secondary:active {
  opacity: 0.8;
}

.btn-secondary.retest-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  color: #fff;
  border: none;
}

/* Knowledge Points Stats */
.kp-stats {
  background: linear-gradient(135deg, #1a1a35 0%, #1a2a35 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid #333;
}

.kp-stats-title {
  display: block;
  font-size: 30rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.kp-stats-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.kp-stat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.kp-stat-name {
  font-size: 28rpx;
  color: #ccc;
  min-width: 200rpx;
}

.kp-stat-bar {
  flex: 1;
  height: 16rpx;
  background: #2a2a4a;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.kp-stat-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.kp-stat-score {
  font-size: 26rpx;
  color: #888;
  min-width: 80rpx;
  text-align: right;
}