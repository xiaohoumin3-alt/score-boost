.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.score-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.kp-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
}

.kp-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.kp-status {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.kp-info {
  flex: 1;
}

.kp-name {
  font-size: 28rpx;
  font-weight: bold;
}

.kp-detail {
  font-size: 24rpx;
  color: #666;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.achievement-badge {
  display: inline-block;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
  margin-right: 10rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-name {
  font-size: 24rpx;
  color: white;
}
