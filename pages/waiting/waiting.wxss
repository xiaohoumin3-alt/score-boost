/* pages/waiting/waiting.wxss */
.waiting-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 加载动画 */
.loading-icon {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 60rpx;
}

.loading-icon .dot {
  width: 20rpx;
  height: 20rpx;
  margin: 0 10rpx;
  background-color: #fff;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-icon .dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-icon .dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 状态文字 */
.status-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 进度信息 */
.progress-info {
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background-color: #fff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 提示文字 */
.tip-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
}

/* 取消按钮 */
.cancel-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.cancel-btn:active {
  background-color: rgba(255, 255, 255, 0.3);
}
