.page {
  min-height: 100vh;
  background: #0f0f23;
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 10rpx;
}

/* Loading */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* Empty State */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #00D9A5 0%, #00B894 100%);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #0f0f23;
  font-weight: bold;
}

/* List */
.list {
  padding: 0 40rpx;
}

.feedback-item {
  background: #1a1a35;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-tag {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.category-tag.category-bug {
  background: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
}

.category-tag.category-suggestion {
  background: rgba(0, 217, 165, 0.15);
  color: #00D9A5;
}

.category-tag.category-other {
  background: rgba(102, 126, 234, 0.15);
  color: #667EEA;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-tag.status-pending {
  background: rgba(255, 193, 7, 0.15);
  color: #FFC107;
}

.status-tag.status-replied {
  background: rgba(0, 217, 165, 0.15);
  color: #00D9A5;
}

.item-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-text {
  font-size: 24rpx;
  color: #444;
}

.reply-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #FF6B6B;
}

.reply-badge .dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF6B6B;
  border-radius: 50%;
}
