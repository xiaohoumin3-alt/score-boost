.container { padding: 30rpx; background: #f5f6fa; min-height: 100vh; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #333; }
.filter-btn { font-size: 28rpx; color: #4a90d9; padding: 10rpx 20rpx; background: #fff; border-radius: 8rpx; }

.review-list { display: flex; flex-direction: column; gap: 16rpx; }

.review-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.review-header { display: flex; justify-content: space-between; align-items: center; }
.review-name { font-size: 28rpx; color: #333; }
.review-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}
.review-status.pending { background: #fff3cd; color: #856404; }
.review-status.approved { background: #d4edda; color: #155724; }
.review-status.rejected { background: #f8d7da; color: #721c24; }

.review-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.loading, .empty { text-align: center; padding: 60rpx; color: #999; }
