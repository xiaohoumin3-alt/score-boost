.page {
  min-height: 100vh;
  background: #0f0f23;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}

.form {
  margin-bottom: 60rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
}

/* 考试模式选择器 */
.mode-selector {
  display: flex;
  gap: 20rpx;
}

.mode-option {
  flex: 1;
  background: #1a1a35;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  border: 2rpx solid #333;
  text-align: center;
  transition: all 0.3s;
}

.mode-option.active {
  border-color: #00D9A5;
  background: rgba(0, 217, 165, 0.1);
}

.mode-name {
  display: block;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 22rpx;
  color: #666;
}

.picker {
  background: #1a1a35;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  border: 2rpx solid #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.value {
  font-size: 32rpx;
  color: #fff;
}

.placeholder {
  font-size: 32rpx;
  color: #555;
}

.arrow {
  font-size: 28rpx;
  color: #00D9A5;
}

.confirm-btn {
  background: linear-gradient(135deg, #00D9A5 0%, #00B894 100%);
  color: #0f0f23;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 28rpx;
  margin-top: 40rpx;
  border: none;
}

.confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}