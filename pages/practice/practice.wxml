<view class="page">
  <view class="loading" wx:if="{{loading && !submitted}}">
    <text class="loading-text">加载题目...</text>
  </view>

  <view class="question-wrap" wx:if="{{!loading && currentQuestion && !submitted}}">
    <!-- Header -->
    <view class="header">
      <view class="kp-badge">
        <text class="kp-icon">📚</text>
        <text class="kp-name">{{kpName}}</text>
      </view>
      <text class="question-num">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
    </view>

    <!-- Progress Bar -->
    <view class="progress-card">
      <view class="progress-bar">
        <view class="bar-fill" style="width: {{progress}}%;"></view>
      </view>
      <text class="progress-hint">已完成 {{progress}}%</text>
    </view>

    <!-- Question -->
    <view class="question-content">
      <text class="question-text">{{currentQuestion.content}}</text>
      <image wx:if="{{currentQuestion.image_url}}"
             class="question-image"
             src="{{currentQuestion.image_url}}"
             mode="widthFix"
             bindtap="previewImage"
             data-url="{{currentQuestion.image_url}}"/>
    </view>

    <!-- Options -->
    <view class="options">
      <block wx:for="{{currentQuestion.parsedOptions}}" wx:key="key">
        <view class="option {{selectedOption === item.key ? 'selected' : ''}} {{questionResults[currentQuestion.id] ? (selectedOption === item.key ? (questionResults[currentQuestion.id].isCorrect ? 'correct' : 'incorrect') : (item.key === questionResults[currentQuestion.id].correctAnswer ? 'correct' : '')) : ''}}" bindtap="selectOption" data-option="{{item.key}}">
          <text class="option-key">{{item.key}}</text>
          <text class="option-text">{{item.value}}</text>
        </view>
      </block>
    </view>

    <!-- Navigation Buttons -->
    <view class="nav-buttons">
      <button
        class="nav-btn nav-prev {{currentIndex === 0 ? 'disabled' : ''}}"
        bindtap="goPrevQuestion"
        disabled="{{currentIndex === 0}}"
      >上一题</button>
      <button
        class="nav-btn nav-next {{currentIndex === questions.length - 1 ? 'submit' : ''}}"
        bindtap="{{currentIndex === questions.length - 1 ? 'submitAll' : 'goNextQuestion'}}"
      >{{currentIndex === questions.length - 1 ? '提交' : '下一题'}}</button>
    </view>
  </view>

  <view class="loading" wx:if="{{submitted && loading}}">
    <text class="loading-text">提交中...</text>
  </view>
</view>