.container {
  padding: 30rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

.header { margin-bottom: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.subtitle { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; }

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.label { font-size: 28rpx; color: #666; margin-bottom: 16rpx; display: block; }

.material-list { display: flex; flex-direction: column; gap: 12rpx; }

.material-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.material-item.selected {
  border-color: #4a90d9;
  background: #e8f4fd;
}

.material-check { margin-right: 16rpx; }
.material-name { font-size: 28rpx; color: #333; display: block; }
.material-meta { font-size: 24rpx; color: #999; display: block; margin-top: 6rpx; }

.picker-value { font-size: 28rpx; color: #333; padding: 16rpx 0; }

.start-btn {
  background: #27ae60;
  color: #fff;
  border-radius: 12rpx;
  margin-top: 30rpx;
  font-size: 30rpx;
}

.start-btn[disabled] { background: #ccc; }

.upload-btn {
  background: #4a90d9;
  color: #fff;
  border-radius: 12rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.empty-icon { font-size: 64rpx; display: block; margin-bottom: 20rpx; }
.empty-msg { font-size: 28rpx; display: block; }

.error-msg {
  background: #fff3f3;
  color: #e74c3c;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  font-size: 26rpx;
}
