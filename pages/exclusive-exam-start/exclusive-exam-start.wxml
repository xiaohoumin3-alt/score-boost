<view class="container">
  <view class="header">
    <text class="title">专属测评</text>
    <text class="subtitle">选择你的学习资料，生成专属题目</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 无资料提示 -->
  <view class="empty" wx:if="{{!loading && materials.length === 0}}">
    <text class="empty-icon">📚</text>
    <text class="empty-msg">暂无学习资料</text>
    <button class="upload-btn" bindtap="goToUpload">去上传资料</button>
  </view>

  <!-- 资料列表 -->
  <view class="section" wx:if="{{materials.length > 0}}">
    <text class="label">选择资料（可多选）</text>
    <view class="material-list">
      <view
        class="material-item {{selectedMaterials.indexOf(item._id) > -1 ? 'selected' : ''}}"
        wx:for="{{materials}}"
        wx:key="_id"
        bindtap="onToggleMaterial"
        data-id="{{item._id}}"
      >
        <view class="material-check">
          <checkbox checked="{{selectedMaterials.indexOf(item._id) > -1}}" />
        </view>
        <view class="material-info">
          <text class="material-name">{{item.file_name}}</text>
          <text class="material-meta">{{item.subject}} · {{item.grade}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 题目数量 -->
  <view class="section" wx:if="{{materials.length > 0}}">
    <text class="label">题目数量</text>
    <slider min="5" max="50" step="5" value="{{numQuestions}}" show-value bindchange="onNumChange" />
  </view>

  <!-- 难度选择 -->
  <view class="section" wx:if="{{materials.length > 0}}">
    <text class="label">难度</text>
    <picker bindchange="onDifficultyChange" range="{{difficulties}}" range-key="label">
      <view class="picker-value">{{difficulty === 'mixed' ? '混合' : difficulty}}</view>
    </picker>
  </view>

  <!-- 开始按钮 -->
  <button
    class="start-btn"
    wx:if="{{materials.length > 0}}"
    bindtap="onStartExam"
    disabled="{{creating || selectedMaterials.length === 0}}"
  >
    {{creating ? '创建中...' : '开始专属测评'}}
  </button>

  <!-- 错误提示 -->
  <view class="error-msg" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>
</view>
