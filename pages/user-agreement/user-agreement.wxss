.container {
  min-height: 100vh;
  background: #0f0f23;
  padding: 40rpx 30rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.content {
  height: calc(100vh - 200rpx);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #00D9A5;
  display: block;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.8;
  display: block;
}