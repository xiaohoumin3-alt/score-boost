.container {
  min-height: 100vh;
  background: #1a1a2e;
  padding: 40rpx 30rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.header { margin-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #fff; }

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 40vh;
}
.loading-text { font-size: 28rpx; color: #888; }

.empty { text-align: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 30rpx; }
.empty-text { display: block; font-size: 32rpx; color: #fff; font-weight: bold; }
.empty-hint { display: block; font-size: 24rpx; color: #666; margin-top: 20rpx; }

.stats-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  background: #25253a;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-primary { border-left: 6rpx solid #667eea; }
.stat-secondary { border-left: 6rpx solid #f093fb; }

.stat-label { font-size: 24rpx; color: #888; display: block; margin-bottom: 10rpx; }
.stat-value { font-size: 56rpx; font-weight: bold; display: block; }
.stat-primary .stat-value { color: #667eea; }
.stat-secondary .stat-value { color: #f093fb; }

.section {
  background: #25253a;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title { font-size: 30rpx; color: #fff; font-weight: bold; }

.improvement { font-size: 26rpx; font-weight: bold; }
.improvement.positive { color: #4caf50; }
.improvement.negative { color: #f44336; }
.improvement.neutral { color: #888; }

/* 趋势图 */
.trend-chart {
  display: flex;
  margin-top: 20rpx;
}

/* Y轴刻度 */
.y-ticks {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-bottom: 60rpx;
  padding-right: 10rpx;
  padding-top: 10rpx;
}

.y-ticks text {
  font-size: 20rpx;
  color: #666;
  text-align: right;
  width: 40rpx;
}

/* 图表区 */
.chart-area {
  flex: 1;
  height: 150rpx;
  position: relative;
}

/* 参考线 */
.ref-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #333;
}

.ref-100 { top: 10rpx; }
.ref-50 { top: 55%; }
.ref-0 { bottom: 50rpx; }

/* 趋势柱容器 */
.trend-bar-wrapper {
  position: absolute;
  bottom: 0;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 趋势柱 */
.trend-bar {
  width: 40rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
}

.trend-bar.latest {
  width: 48rpx;
  background: linear-gradient(180deg, #4caf50 0%, #2e7d32 100%);
}

/* 数据点和标签 */
.trend-dot {
  margin-top: 10rpx;
  text-align: center;
}

.trend-dot text {
  font-size: 22rpx;
  color: #aaa;
  font-weight: bold;
}

.trend-dot.latest text {
  color: #4caf50;
  font-size: 26rpx;
}

/* X轴 */
.x-axis {
  display: flex;
  justify-content: space-between;
  padding-left: 50rpx;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #666;
}

/* 历史列表 */
.record-item {
  background: #2d2d4a;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-item.latest {
  background: rgba(102, 126, 234, 0.15);
  border: 2rpx solid rgba(102, 126, 234, 0.3);
}

.record-score-circle {
  width: 80rpx;
  height: 80rpx;
  background: #667eea;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-text { color: white; font-size: 32rpx; font-weight: bold; }

.record-info { flex: 1; }
.record-name { font-size: 28rpx; color: #fff; font-weight: 500; display: block; }
.record-date { font-size: 24rpx; color: #888; margin-top: 6rpx; display: block; }

.latest-badge { font-size: 22rpx; color: #667eea; font-weight: bold; flex-shrink: 0; }
