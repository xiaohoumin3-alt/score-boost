<view class="container">
  <view class="header">
    <text class="title">学情分析</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 无数据 -->
  <view class="empty" wx:if="{{!loading && assessments.length === 0}}">
    <text class="empty-icon">📊</text>
    <text class="empty-text">还没有测评记录</text>
    <text class="empty-hint">完成一次测评后，这里会显示你的进步情况</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row" wx:if="{{!loading && assessments.length > 0}}">
    <view class="stat-card stat-primary">
      <text class="stat-label">总测评次数</text>
      <text class="stat-value">{{stats.total}}</text>
    </view>
    <view class="stat-card stat-secondary">
      <text class="stat-label">平均分</text>
      <text class="stat-value">{{stats.average}}</text>
    </view>
  </view>

  <!-- 进步趋势 -->
  <view class="section" wx:if="{{!loading && linePoints.length >= 2}}">
    <view class="section-header">
      <text class="section-title">📈 进步趋势</text>
      <text wx:if="{{stats.improvement !== null}}" class="improvement {{stats.improvement > 0 ? 'positive' : (stats.improvement < 0 ? 'negative' : 'neutral')}}">
        {{stats.improvement > 0 ? '↑ +' : (stats.improvement < 0 ? '↓ ' : '')}}{{stats.improvement}}分
      </text>
    </view>

    <!-- 趋势图 -->
    <view class="trend-chart">
      <!-- Y轴刻度 -->
      <view class="y-ticks">
        <text>100</text>
        <text>50</text>
        <text>0</text>
      </view>

      <!-- 图表区 -->
      <view class="chart-area">
        <!-- 水平参考线 -->
        <view class="ref-line ref-100"></view>
        <view class="ref-line ref-50"></view>
        <view class="ref-line ref-0"></view>

        <!-- 垂直趋势柱 -->
        <block wx:for="{{linePoints}}" wx:key="index">
          <view
            class="trend-bar-wrapper"
            style="left: {{item.leftPercent}}%;"
          >
            <view
              class="trend-bar {{item.isLatest ? 'latest' : ''}}"
              style="height: {{item.heightPercent}}rpx;"
            ></view>
            <view class="trend-dot {{item.isLatest ? 'latest' : ''}}">
              <text>{{item.score}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- X轴 -->
    <view class="x-axis">
      <text>第一次测评</text>
      <text>最近测评</text>
    </view>
  </view>

  <!-- 历史记录列表 -->
  <view class="section" wx:if="{{!loading && assessments.length > 0}}">
    <text class="section-title">📋 测评历史</text>
    <block wx:for="{{assessments}}" wx:key="assessment_id">
      <view class="record-item {{index === 0 ? 'latest' : ''}}">
        <view class="record-score-circle">
          <text class="score-text">{{item.score_percent || 0}}</text>
        </view>
        <view class="record-info">
          <text class="record-name">{{item.subject || subject}}测评</text>
          <text class="record-date">{{formatDate(item.created_at)}}</text>
        </view>
        <text wx:if="{{index === 0}}" class="latest-badge">最新</text>
      </view>
    </block>
  </view>
</view>
